// 智能标书库 · Prisma Schema 示例（按模块分块注释，便于定位）
// 使用方式：复制到项目根目录 prisma/schema.prisma 后执行 prisma generate / migrate

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ========== 模块 2/3：用户与人员配置 ==========
model User {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  name      String?
  contact   String?
  role      String   // 管理员|技术标制作人|商务制作人|机动人员|初审人员|复审人员
  superior  String?
  status    String   @default("启用") // 启用|禁用
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ========== 模块 4：项目与看板 ==========
model Project {
  id                 String    @id @default(cuid())
  name               String
  owner              String?
  deadline           String?
  progress           String?
  type               String?   // 信息化/云平台/金融等
  status             String    @default("pending") // pending|ongoing|review|done
  archivedAt         DateTime?
  tenderOutline      String?   @map("tender_outline")
  techOutlineSections Json?    @map("tech_outline_sections") // OutlineGroup[]
  bizOutlineSections  Json?    @map("biz_outline_sections")
  proposalStatus     String?  @map("proposal_status") // 待编制|待初审|待复审|已通过|已驳回
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  sections    SectionContent[]
  assignments SectionAssignment[]
  tasks       Task[]
  tenderFiles TenderFile[]
  parseTasks  TenderParseTask[]
  review      ReviewRecord?
  rivals      RivalProject[]
}

// ========== 模块 5：标书解析 ==========
model TenderFile {
  id         String   @id @default(cuid())
  projectId  String   @map("project_id")
  fileKey    String   @map("file_key")   // 对象存储 key
  fileName   String   @map("file_name")
  size       Int?
  createdAt  DateTime @default(now())

  project    Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parseTasks TenderParseTask[]
}


model TenderParseTask {
  id        String   @id @default(cuid())
  projectId String   @map("project_id")
  fileId    String?  @map("file_id")
  status    String   @default("pending") // pending|running|done
  progress  Int      @default(0)
  result    Json?    // 解析结果，与前端读标结构一致
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  file    TenderFile? @relation(fields: [fileId], references: [id], onDelete: SetNull)
}

// ========== 模块 6：标书编制（章节内容） ==========
model SectionContent {
  id           String   @id @default(cuid())
  projectId    String   @map("project_id")
  sectionKey   String   @map("section_key") // 如 "一、资信标::资格证明文件"
  content      String   @db.Text
  version      Int      @default(1)
  completed    Boolean  @default(false)
  lastEditedAt DateTime? @map("last_edited_at")
  lastEditedBy String?  @map("last_edited_by")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, sectionKey])
}

// ========== 模块 7：章节分配 ==========
model SectionAssignment {
  id        String   @id @default(cuid())
  projectId String   @map("project_id")
  sectionKey String  @map("section_key")
  username  String
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, sectionKey, username])
  @@index([projectId])
}

// ========== 模块 8：协作任务与审批 ==========
model Task {
  id          String   @id @default(cuid())
  projectId   String   @map("project_id")
  name        String
  taskType    String   @map("task_type")   // 标书制作人员分配|标书审核任务
  requirement String?  @db.Text
  urgency     String?  // 高|中|低
  sectionKey  String?  @map("section_key")
  status      String   @default("待分配")   // 待分配|进行中|已完成|已驳回
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project     Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignments TaskAssignment[]
  history     TaskHistory[]
}

model TaskAssignment {
  id         String   @id @default(cuid())
  taskId     String   @map("task_id")
  username   String
  roleName   String?  @map("role_name")
  assignedAt DateTime @default(now()) @map("assigned_at")
  progress   String?  @default("0%")

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([taskId, username])
}

model TaskHistory {
  id        String   @id @default(cuid())
  taskId    String   @map("task_id")
  at        DateTime @default(now())
  status    String
  note      String?  @db.Text
  operator  String

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

// ========== 模块 9：企业库 ==========
model Asset {
  id         String   @id @default(cuid())
  category   String   // qualification|performance|solution|archive|winning|resume
  title      String
  fileUrl    String?  @map("file_url")
  content    String?  @db.Text
  snippet    String?  @db.Text
  tags       Json?    // string[]
  uploadedBy String?  @map("uploaded_by")
  uploadedAt DateTime @default(now()) @map("uploaded_at")
  updatedAt  DateTime @updatedAt
}

// ========== 模块 10：复盘与竞争对手 ==========
model ReviewRecord {
  id              String   @id @default(cuid())
  projectId       String   @unique @map("project_id")
  result          String   // 中标|落标
  reason          String?  @db.Text
  improvements    String?  @db.Text
  scoreBreakdown  Json?    @map("score_breakdown")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Rival {
  id        String   @id @default(cuid())
  name      String
  price     String?
  advantage String?  @db.Text
  weakness  String?  @db.Text
  strategy  String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projects RivalProject[]
}

model RivalProject {
  rivalId   String @map("rival_id")
  projectId String @map("project_id")

  rival   Rival   @relation(fields: [rivalId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@id([rivalId, projectId])
}

// ========== 模块 11：系统设置 ==========
model SystemConfig {
  id    String @id @default(cuid())
  key   String @unique   // 如 "model_config"
  value Json
  updatedAt DateTime @updatedAt
}

