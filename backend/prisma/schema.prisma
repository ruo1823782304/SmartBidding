generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum DocumentType {
  TENDER
  ASSET
  HISTORY_PROPOSAL
  EXPORT
}

enum DocumentBizCategory {
  TENDER_SOURCE
  COMPANY_PROFILE
  CASE_STUDY
  QUALIFICATION
  FINANCIAL
  CONTRACT
  OTHER
}

enum DocumentStatus {
  UPLOADED
  PARSING
  READY
  FAILED
}

enum ParseJobType {
  TENDER_PARSE
  ASSET_PARSE
  REINDEX
}

enum ParseJobStatus {
  PENDING
  RUNNING
  SUCCEEDED
  FAILED
}

enum ParseJobStage {
  UPLOAD
  DOCLING
  BLOCK_EXTRACT
  CHUNK_INDEX
  LLM_EXTRACT
  FINALIZE
}

enum BlockType {
  TITLE
  HEADING
  PARAGRAPH
  LIST_ITEM
  TABLE
  TABLE_ROW
  TABLE_CELL
}

enum ChunkType {
  SECTION_SUMMARY
  PARAGRAPH_WINDOW
  TABLE_REQUIREMENT
  QUALIFICATION_CLAUSE
  REVIEW_RULE
  SUBMISSION_LIST
}

enum MajorParseCode {
  basic_info
  qualification_requirements
  review_requirements
  bid_document_requirements
  invalid_and_rejection
  required_submission_documents
  tender_document_review
  other
}

enum ParseReviewStatus {
  AUTO
  CONFIRMED
  CORRECTED
}

enum RiskLevel {
  low
  medium
  high
}

enum RetrievalScene {
  PARSE
  PROPOSAL_ASSIST
  ASSET_SEARCH
}

enum RetrievalStrategy {
  BM25
  VECTOR
  HYBRID
}

enum RetrievalSource {
  TENDER
  ASSET
  HISTORY
}

enum GenerationScene {
  TENDER_PARSE
  SECTION_DRAFT
  SECTION_REWRITE
  QA
}

enum GenerationStatus {
  SUCCEEDED
  FAILED
}

enum EvidenceSourceType {
  TENDER
  ASSET
  HISTORY
}

enum EvidenceUsedFor {
  DIRECT_QUOTE
  FACT_REFERENCE
  DRAFT_SUPPORT
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  name      String?
  contact   String?
  role      String
  superior  String?
  status    String   @default("enabled")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Project {
  id                  String           @id @default(cuid())
  name                String
  owner               String?
  deadline            String?
  progress            String?
  type                String?
  status              String           @default("pending")
  archivedAt          DateTime?
  tenderOutline       String?          @map("tender_outline")
  techOutlineSections Json?            @map("tech_outline_sections")
  bizOutlineSections  Json?            @map("biz_outline_sections")
  proposalStatus      String?          @map("proposal_status")
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  sections        SectionContent[]
  assignments     SectionAssignment[]
  tasks           Task[]
  tenderFiles     TenderFile[]
  parseTasks      TenderParseTask[]
  review          ReviewRecord?
  rivals          RivalProject[]
  documents       Document[]
  parseJobs       ParseJob[]
  parseResults    ParseResult[]
  retrievalLogs   RetrievalLog[]
  generationLogs  GenerationLog[]
  sectionEvidence SectionEvidence[]
}

model TenderFile {
  id                String           @id @default(cuid())
  projectId         String           @map("project_id")
  fileKey           String           @map("file_key")
  fileName          String           @map("file_name")
  size              Int?
  documentId        String?          @map("document_id")
  documentVersionId String?          @map("document_version_id")
  createdAt         DateTime         @default(now())

  project         Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parseTasks      TenderParseTask[]
  document        Document?        @relation(fields: [documentId], references: [id], onDelete: SetNull)
  documentVersion DocumentVersion? @relation(fields: [documentVersionId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([documentId])
  @@index([documentVersionId])
}

model TenderParseTask {
  id        String   @id @default(cuid())
  projectId String   @map("project_id")
  fileId    String?  @map("file_id")
  status    String   @default("pending")
  progress  Int      @default(0)
  result    Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  file    TenderFile? @relation(fields: [fileId], references: [id], onDelete: SetNull)
}

model SectionContent {
  id           String    @id @default(cuid())
  projectId    String    @map("project_id")
  sectionKey   String    @map("section_key")
  content      String    @db.Text
  version      Int       @default(1)
  completed    Boolean   @default(false)
  lastEditedAt DateTime? @map("last_edited_at")
  lastEditedBy String?   @map("last_edited_by")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  project   Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  evidence  SectionEvidence[]

  @@unique([projectId, sectionKey])
}

model SectionAssignment {
  id         String   @id @default(cuid())
  projectId  String   @map("project_id")
  sectionKey String   @map("section_key")
  username   String
  createdAt  DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, sectionKey, username])
  @@index([projectId])
}

model Task {
  id          String   @id @default(cuid())
  projectId   String   @map("project_id")
  name        String
  taskType    String   @map("task_type")
  requirement String?  @db.Text
  urgency     String?
  sectionKey  String?  @map("section_key")
  status      String   @default("pending")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project     Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignments TaskAssignment[]
  history     TaskHistory[]
}

model TaskAssignment {
  id         String   @id @default(cuid())
  taskId     String   @map("task_id")
  username   String
  roleName   String?  @map("role_name")
  assignedAt DateTime @default(now()) @map("assigned_at")
  progress   String?  @default("0%")

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([taskId, username])
}

model TaskHistory {
  id       String   @id @default(cuid())
  taskId   String   @map("task_id")
  at       DateTime @default(now())
  status   String
  note     String?  @db.Text
  operator String

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

model Asset {
  id         String     @id @default(cuid())
  category   String
  title      String
  fileUrl    String?    @map("file_url")
  content    String?    @db.Text
  snippet    String?    @db.Text
  tags       Json?
  uploadedBy String?    @map("uploaded_by")
  uploadedAt DateTime   @default(now()) @map("uploaded_at")
  updatedAt  DateTime   @updatedAt

  documents  Document[]
}

model ReviewRecord {
  id             String   @id @default(cuid())
  projectId      String   @unique @map("project_id")
  result         String
  reason         String?  @db.Text
  improvements   String?  @db.Text
  scoreBreakdown Json?    @map("score_breakdown")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Rival {
  id        String   @id @default(cuid())
  name      String
  price     String?
  advantage String?  @db.Text
  weakness  String?  @db.Text
  strategy  String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projects RivalProject[]
}

model RivalProject {
  rivalId   String @map("rival_id")
  projectId String @map("project_id")

  rival   Rival   @relation(fields: [rivalId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@id([rivalId, projectId])
}

model SystemConfig {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  updatedAt DateTime @updatedAt
}

model Document {
  id               String             @id @default(cuid())
  projectId        String?            @map("project_id")
  assetId          String?            @map("asset_id")
  documentType     DocumentType       @map("document_type")
  bizCategory      DocumentBizCategory @default(OTHER) @map("biz_category")
  title            String
  mimeType         String?            @map("mime_type")
  fileExt          String?            @map("file_ext")
  currentVersionId String?            @unique @map("current_version_id")
  status           DocumentStatus     @default(UPLOADED)
  createdBy        String?            @map("created_by")
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  project        Project?           @relation(fields: [projectId], references: [id], onDelete: SetNull)
  asset          Asset?             @relation(fields: [assetId], references: [id], onDelete: SetNull)
  currentVersion DocumentVersion?   @relation("CurrentDocumentVersion", fields: [currentVersionId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  versions       DocumentVersion[]  @relation("DocumentVersions")
  parseJobs      ParseJob[]
  parseResults   ParseResult[]
  chunks         DocumentChunk[]
  tenderFiles    TenderFile[]
  sectionEvidence SectionEvidence[]

  @@index([projectId, documentType])
  @@index([assetId])
  @@index([status])
}

model DocumentVersion {
  id             String          @id @default(cuid())
  documentId     String          @map("document_id")
  versionNo      Int             @map("version_no")
  storageBucket  String          @map("storage_bucket")
  storageKey     String          @map("storage_key")
  fileName       String          @map("file_name")
  fileSize       Int?            @map("file_size")
  contentHash    String?         @map("content_hash")
  parseStatus    ParseJobStatus  @default(PENDING) @map("parse_status")
  createdBy      String?         @map("created_by")
  createdAt      DateTime        @default(now())

  document         Document           @relation("DocumentVersions", fields: [documentId], references: [id], onDelete: Cascade)
  currentFor       Document?          @relation("CurrentDocumentVersion")
  pages            DocumentPage[]
  blocks           DocumentBlock[]
  chunks           DocumentChunk[]
  parseJobs        ParseJob[]
  parseResults     ParseResult[]
  tenderFiles      TenderFile[]
  sectionEvidence  SectionEvidence[]

  @@unique([documentId, versionNo])
  @@index([documentId, parseStatus])
  @@index([contentHash])
}

model DocumentPage {
  id                String   @id @default(cuid())
  documentVersionId String   @map("document_version_id")
  pageNo            Int      @map("page_no")
  width             Float?
  height            Float?
  rotation          Int?
  imageKey          String?  @map("image_key")

  documentVersion DocumentVersion @relation(fields: [documentVersionId], references: [id], onDelete: Cascade)
  blocks          DocumentBlock[]

  @@unique([documentVersionId, pageNo])
}

model DocumentBlock {
  id                String          @id @default(cuid())
  documentVersionId String          @map("document_version_id")
  pageId            String?         @map("page_id")
  blockType         BlockType       @map("block_type")
  sectionPath       String?         @map("section_path")
  headingLevel      Int?            @map("heading_level")
  paragraphNo       Int?            @map("paragraph_no")
  text              String          @db.Text
  textHash          String?         @map("text_hash")
  tokens            Int?
  bbox              Json?
  charStart         Int?            @map("char_start")
  charEnd           Int?            @map("char_end")
  metadata          Json?
  createdAt         DateTime        @default(now())

  documentVersion DocumentVersion @relation(fields: [documentVersionId], references: [id], onDelete: Cascade)
  page            DocumentPage?    @relation(fields: [pageId], references: [id], onDelete: SetNull)

  @@index([documentVersionId, pageId])
  @@index([documentVersionId, blockType])
  @@index([documentVersionId, paragraphNo])
  @@index([documentVersionId, textHash])
}

model DocumentChunk {
  id                String                 @id @default(cuid())
  documentVersionId String                 @map("document_version_id")
  documentId        String                 @map("document_id")
  chunkType         ChunkType              @map("chunk_type")
  sourceBlockIds    Json                   @map("source_block_ids")
  sectionPath       String?                @map("section_path")
  pageStart         Int?                   @map("page_start")
  pageEnd           Int?                   @map("page_end")
  text              String                 @db.Text
  textForEmbedding  String?                @map("text_for_embedding") @db.Text
  keywords          Json?
  tsv               Unsupported("tsvector")?
  embedding         Json?
  importanceScore   Float?                 @map("importance_score")
  documentType      DocumentType           @map("document_type")
  bizCategory       DocumentBizCategory    @default(OTHER) @map("biz_category")
  versionNo         Int                    @map("version_no")
  createdAt         DateTime               @default(now())

  document         Document             @relation(fields: [documentId], references: [id], onDelete: Cascade)
  documentVersion  DocumentVersion      @relation(fields: [documentVersionId], references: [id], onDelete: Cascade)
  retrievalHits    RetrievalLogHit[]
  generationCitations GenerationCitation[]
  sectionEvidence  SectionEvidence[]

  @@index([documentVersionId, sectionPath])
  @@index([documentType, bizCategory])
  @@index([documentId, versionNo])
}

model ParseJob {
  id                String         @id @default(cuid())
  projectId         String?        @map("project_id")
  documentId        String         @map("document_id")
  documentVersionId String         @map("document_version_id")
  jobType           ParseJobType   @map("job_type")
  status            ParseJobStatus @default(PENDING)
  progress          Int            @default(0)
  currentStage      ParseJobStage? @map("current_stage")
  errorMessage      String?        @map("error_message") @db.Text
  startedAt         DateTime?      @map("started_at")
  finishedAt        DateTime?      @map("finished_at")
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  project         Project?        @relation(fields: [projectId], references: [id], onDelete: SetNull)
  document        Document        @relation(fields: [documentId], references: [id], onDelete: Cascade)
  documentVersion DocumentVersion @relation(fields: [documentVersionId], references: [id], onDelete: Cascade)
  parseResult     ParseResult?

  @@index([projectId, createdAt])
  @@index([documentVersionId, status])
}

model ParseResult {
  id                String     @id @default(cuid())
  parseJobId        String     @unique @map("parse_job_id")
  projectId         String?    @map("project_id")
  documentId        String     @map("document_id")
  documentVersionId String     @map("document_version_id")
  schemaVersion     String     @map("schema_version")
  promptVersion     String     @map("prompt_version")
  modelProvider     String     @map("model_provider")
  modelName         String     @map("model_name")
  status            String
  summary           String?    @db.Text
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  parseJob         ParseJob           @relation(fields: [parseJobId], references: [id], onDelete: Cascade)
  project          Project?           @relation(fields: [projectId], references: [id], onDelete: SetNull)
  document         Document           @relation(fields: [documentId], references: [id], onDelete: Cascade)
  documentVersion  DocumentVersion    @relation(fields: [documentVersionId], references: [id], onDelete: Cascade)
  items            ParseResultItem[]

  @@index([projectId, createdAt])
  @@index([documentVersionId, schemaVersion])
}

model ParseResultItem {
  id                String            @id @default(cuid())
  parseResultId     String            @map("parse_result_id")
  majorCode         MajorParseCode    @map("major_code")
  minorCode         String            @map("minor_code")
  title             String
  content           String            @db.Text
  normalizedValue   Json?             @map("normalized_value")
  confidence        Float?
  priority          String?
  isRequired        Boolean           @default(false) @map("is_required")
  riskLevel         RiskLevel         @default(low) @map("risk_level")
  sourceParagraphIds Json             @map("source_paragraph_ids")
  sourceChunkIds    Json              @map("source_chunk_ids")
  sourceQuote       String?           @map("source_quote") @db.Text
  reviewStatus      ParseReviewStatus @default(AUTO) @map("review_status")
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  parseResult ParseResult @relation(fields: [parseResultId], references: [id], onDelete: Cascade)

  @@index([parseResultId, majorCode])
  @@index([parseResultId, majorCode, minorCode])
  @@index([riskLevel])
}

model RetrievalLog {
  id                String            @id @default(cuid())
  projectId         String?           @map("project_id")
  scene             RetrievalScene
  queryText         String            @map("query_text") @db.Text
  queryIntent       String?           @map("query_intent")
  filters           Json?
  topK              Int               @default(10) @map("top_k")
  retrievalStrategy RetrievalStrategy @map("retrieval_strategy")
  createdBy         String?           @map("created_by")
  createdAt         DateTime          @default(now())

  project Project?         @relation(fields: [projectId], references: [id], onDelete: SetNull)
  hits    RetrievalLogHit[]
}

model RetrievalLogHit {
  id               String           @id @default(cuid())
  retrievalLogId   String           @map("retrieval_log_id")
  chunkId          String           @map("chunk_id")
  source           RetrievalSource
  bm25Score        Float?           @map("bm25_score")
  vectorScore      Float?           @map("vector_score")
  hybridScore      Float?           @map("hybrid_score")
  rankBeforeRerank Int?             @map("rank_before_rerank")
  rankAfterRerank  Int?             @map("rank_after_rerank")
  isSelected       Boolean          @default(false) @map("is_selected")

  retrievalLog RetrievalLog @relation(fields: [retrievalLogId], references: [id], onDelete: Cascade)
  chunk        DocumentChunk @relation(fields: [chunkId], references: [id], onDelete: Cascade)

  @@index([retrievalLogId, rankAfterRerank])
}

model GenerationLog {
  id            String           @id @default(cuid())
  projectId     String?          @map("project_id")
  scene         GenerationScene
  provider      String
  modelName     String           @map("model_name")
  modelVersion  String?          @map("model_version")
  temperature   Float?
  promptVersion String           @map("prompt_version")
  systemPrompt  String?          @map("system_prompt") @db.Text
  userPrompt    String?          @map("user_prompt") @db.Text
  responseText  String?          @map("response_text") @db.Text
  responseJson  Json?            @map("response_json")
  status        GenerationStatus
  errorMessage  String?          @map("error_message") @db.Text
  latencyMs     Int?             @map("latency_ms")
  tokenUsage    Json?            @map("token_usage")
  createdAt     DateTime         @default(now())

  project    Project?              @relation(fields: [projectId], references: [id], onDelete: SetNull)
  citations  GenerationCitation[]
}

model GenerationCitation {
  id              String   @id @default(cuid())
  generationLogId String   @map("generation_log_id")
  chunkId         String   @map("chunk_id")
  blockIds        Json     @map("block_ids")
  quote           String   @db.Text
  citationOrder   Int      @map("citation_order")

  generationLog GenerationLog @relation(fields: [generationLogId], references: [id], onDelete: Cascade)
  chunk         DocumentChunk @relation(fields: [chunkId], references: [id], onDelete: Cascade)
}

model SectionEvidence {
  id                String             @id @default(cuid())
  projectId         String             @map("project_id")
  sectionKey        String             @map("section_key")
  sectionContentId  String?            @map("section_content_id")
  sourceType        EvidenceSourceType @map("source_type")
  documentId        String             @map("document_id")
  documentVersionId String             @map("document_version_id")
  chunkId           String             @map("chunk_id")
  blockIds          Json               @map("block_ids")
  quote             String             @db.Text
  usedFor           EvidenceUsedFor    @map("used_for")
  createdBy         String?            @map("created_by")
  createdAt         DateTime           @default(now())

  project         Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sectionContent  SectionContent?  @relation(fields: [sectionContentId], references: [id], onDelete: SetNull)
  document        Document         @relation(fields: [documentId], references: [id], onDelete: Cascade)
  documentVersion DocumentVersion  @relation(fields: [documentVersionId], references: [id], onDelete: Cascade)
  chunk           DocumentChunk    @relation(fields: [chunkId], references: [id], onDelete: Cascade)

  @@index([projectId, sectionKey])
  @@index([sectionContentId])
}
